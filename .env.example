# ============================================================
# NEPCO FieldOps — Environment Variables Template
# Copy this file to .env.local and fill in values.
# NEVER commit .env.local or any file containing real secrets.
# All production secrets are managed via Infisical.
# ============================================================

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Service role key — used ONLY by apps/api background jobs, NEVER by clients
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Upstash Redis (rate limiting + BullMQ) ---
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# --- Cloudflare R2 (photo + report storage) ---
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=fieldops-reports
R2_PUBLIC_URL=https://your-bucket.r2.dev

# --- Resend (email delivery) ---
RESEND_API_KEY=re_your_key

# --- Twilio (SMS fallback) ---
TWILIO_ACCOUNT_SID=ACyour-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+1234567890

# --- Mapbox (web map picker) ---
VITE_MAPBOX_TOKEN=pk.your-mapbox-token

# --- Sentry (error tracking) ---
SENTRY_DSN=https://your-dsn@sentry.io/project
VITE_SENTRY_DSN=https://your-dsn@sentry.io/project

# --- API ---
API_PORT=3000
API_BASE_URL=http://localhost:3000
NODE_ENV=development
