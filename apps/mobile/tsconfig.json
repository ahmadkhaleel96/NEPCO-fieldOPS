{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "module": "commonjs",
    "paths": {
      "@fieldops/shared": [
        "../../packages/shared/src/index.ts"
      ]
    }
  },
  "include": [
    "src",
    "app",
    "app.json",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "src/__tests__"
  ]
}
